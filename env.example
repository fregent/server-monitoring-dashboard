# ──────────────────────────────────────────
# Copier ce fichier en .env et renseigner
# les valeurs réelles. Ne jamais committer .env
# ──────────────────────────────────────────

# Port d'écoute du serveur
PORT=3000

# Secret de session — utiliser une chaîne longue et aléatoire en production
# Exemple de génération : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=remplacer_par_un_secret_long_et_aleatoire

# Identifiant administrateur
ADMIN_USERNAME=admin

# Hash bcrypt du mot de passe administrateur
# Générer avec : node -e "const b = require('bcryptjs'); b.hash('votre_mot_de_passe', 10).then(console.log)"
ADMIN_PASSWORD_HASH=remplacer_par_le_hash_bcrypt_genere
